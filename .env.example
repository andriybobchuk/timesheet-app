# Notion (server-side, set in Netlify dashboard)
NOTION_API_KEY=your-notion-integration-secret
NOTION_DATABASE_ID=your-notion-database-id

# Telegram notifications (server-side, set in Netlify dashboard)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Submitter names shown in the dropdown (client-side)
VITE_SUBMITTERS=Accountant,Sister,Friend
